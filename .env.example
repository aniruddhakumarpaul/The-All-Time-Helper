# Copy this file to .env and fill only local/private values.
# Never commit your real .env file.

# Core security
SECRET_KEY=change-this-local-secret
ADMIN_KEY=change-this-admin-key

# Database
DB_FILE=users.db

# Cloud model routing through OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_FREE_MAX_TOKENS=2048
OPENROUTER_MAX_TOKENS=4096

# Local Ollama
OLLAMA_URL=http://localhost:11434

# Email mode
# Use SIMULATE until SMTP is fully tested.
EMAIL_MODE=SIMULATE
SENDER_EMAIL=
SENDER_PWD=

# Optional local tunnel
# Keep disabled unless you specifically need public access.
ENABLE_NGROK=false
NGROK_TOKEN=
# Optional: set when pyngrok cannot install or execute its bundled ngrok binary on Windows.
# Example: NGROK_PATH=C:\Tools\ngrok\ngrok.exe
NGROK_PATH=

# Optional CORS origins
ALLOWED_ORIGINS=http://localhost:9000
